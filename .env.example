# Application
APP_NAME=llm-wiki-consumer
APP_ENV=development
DEBUG=true

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=wiki
POSTGRES_PASSWORD=wiki_secret
POSTGRES_DB=llm_wiki

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=wiki_chunks

# LLM
LLM_API_KEY=
LLM_MODEL=gpt-4
LLM_BASE_URL=https://api.openai.com/v1
